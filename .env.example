# =============================================================================
# llm-extractor environment configuration
# =============================================================================
#
# Copy this file to .env for local development:
#
#   cp .env.example .env
#
# Do not commit real secrets in .env.
# This project currently reads environment variables from the process environment.
# If you use Docker, pass this file with:
#
#   docker run --env-file .env ...
#
# Or export variables in your shell before running the app.
# =============================================================================


# -----------------------------------------------------------------------------
# API authentication
# -----------------------------------------------------------------------------
# Required for protected endpoints.
# Clients must send this value in the X-API-Key header.
APP_API_KEY=change-me-local-dev-key


# -----------------------------------------------------------------------------
# SQLite storage
# -----------------------------------------------------------------------------
# Main application database used by document store, ingestion jobs,
# evaluation results, and usage tracking.
APP_DB_PATH=app.db

# Temporary uploaded-text staging database.
# Used for pointer-based ingestion payloads before/while background processing runs.
APP_UPLOADED_TEXT_DB_PATH=uploaded_texts.db


# -----------------------------------------------------------------------------
# Uploaded-text retention
# -----------------------------------------------------------------------------
# Default retention window for stale staged uploads.
# The cleanup endpoint can override this per request.
#
# Conservative default: 24 hours.
# Keep this larger than the maximum expected queue delay + processing delay.
APP_UPLOADED_TEXT_CLEANUP_MAX_AGE_HOURS=24


# -----------------------------------------------------------------------------
# Extraction backend
# -----------------------------------------------------------------------------
# Supported values:
#   rule
#   mock_llm
#   mock_llm_json
#
# rule is deterministic and safe for local development/tests.
EXTRACTOR_TYPE=rule


# -----------------------------------------------------------------------------
# Order tool integration
# -----------------------------------------------------------------------------
# Supported values:
#   local
#   http
#   http_with_fallback
#
# local uses in-memory fixture data.
# http calls an external order API.
# http_with_fallback calls the external API first and falls back to local fixtures.
ORDER_CLIENT_TYPE=local

# Required when ORDER_CLIENT_TYPE=http or http_with_fallback.
ORDER_API_BASE_URL=

# Optional bearer token/API key for the external order API.
ORDER_API_KEY=